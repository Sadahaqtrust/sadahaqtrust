[Unit]
Description=Next.js Storefront
After=network.target medusa.service
Requires=medusa.service

[Service]
Type=simple
User=sadahaqtrust
WorkingDirectory=/home/sadahaqtrust/storefront
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=10
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target